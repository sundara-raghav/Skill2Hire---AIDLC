# Environment Variables — Skill2Hire
# Copy this file to .env and fill in your values

# ── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# ── Flask ─────────────────────────────────────────────────
FLASK_ENV=development
PORT=5000

# ── ML Pipeline ───────────────────────────────────────────
DATASET_SIZE=1000
RANDOM_SEED=42
